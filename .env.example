# --- API (Settings → API) — used for database project; admin uses key-sequence gate ---
NEXT_PUBLIC_SUPABASE_URL=https://txaqzyddienpsiytkzwe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Signs the admin session cookie (set a long random string in production)
ADMIN_SESSION_SECRET=generate-a-long-random-string

# Server-only — required for image uploads (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin gate cookie signing
ADMIN_SESSION_SECRET=generate-a-long-random-stringyour-service-role-key

# --- PostgreSQL (Settings → Database → Connection string) ---

# Option A — Direct (IPv6). Works if your network supports IPv6.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.txaqzyddienpsiytkzwe.supabase.co:5432/postgres

# Option B — Session pooler (recommended on IPv4 / Windows / many home networks)
# Settings → Database → Connection string → "Session pooler" → URI
# Host looks like: aws-0-<region>.pooler.supabase.com
# User looks like: postgres.txaqzyddienpsiytkzwe
DATABASE_URL=postgresql://postgres.txaqzyddienpsiytkzwe:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Drizzle CLI (db:push, db:seed) reads DATABASE_URL from .env.local via dotenv.
